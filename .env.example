# SubSpace Cold Outreach Pipeline — Environment Variables

# API Keys (leave blank to use mock data)
OCEAN_IO_API_KEY=
PROSPEO_API_KEY=
EAZYREACH_API_KEY=
BREVO_API_KEY=

# REQUIRED: Must match a verified sender domain in your Brevo account
# Replace yourdomain.com with your actual Namecheap domain
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=Outreach Team

# App
DEBUG=True

# Frontend API URL (for Docker)
VITE_API_URL=http://localhost:8000/api
